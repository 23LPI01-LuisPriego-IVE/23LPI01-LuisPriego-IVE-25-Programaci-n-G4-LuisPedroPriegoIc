Algoritmo Act2_Lecc24_inciso1
		Definir n, i, multiplo Como Entero
		
		Escribir "Ingrese el numero del cual desea conocer sus multiplos:"
		Leer n
		
		Escribir "Los primeros 20 multiplos de ", n, " son:"
		
		Para i = 1 Hasta 20 Hacer
			multiplo = n * i
			Escribir n, " x ", i, " = ", multiplo
		Fin Para
		
FinAlgoritmo

